# Copy this file to .env and fill in your values. Never commit .env to version control.

# Database
# MySQL (Docker/production):
# DATABASE_URL=mysql+pymysql://rednote:rednote@localhost:3306/rednote
# SQLite local dev (start-backend.ps1 runs from backend/):
DATABASE_URL=sqlite:///./rednote_dev.db

# OpenAI-compatible LLM (官方或代理，如 PPIO)
OPENAI_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
# PPIO 示例: LLM_BASE_URL=https://api.ppio.com/openai  (代码会自动补 /v1)
LLM_MODEL=deepseek/deepseek-r1
IDEATION_LLM_MODEL=deepseek/deepseek-v3
IDEATION_LLM_TIMEOUT=90

# TMDB (v3 API Key — 用于影片调研)
TMDB_API_KEY=your_tmdb_api_key_here
# TMDB v4 Read Access Token（可选，当前后端未使用）
# TMDB_READ_ACCESS_TOKEN=your_read_access_token_here

# Auth (single-user API key for MVP)
API_SECRET_KEY=change_me_in_production

# Frontend (browser calls backend API)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production CORS (comma-separated frontend origins)
CORS_ORIGINS=http://localhost:3000

# Image generation (PPIO 环境默认走 PPIO 文生图 API)
IMAGE_PROVIDER=auto
IMAGE_USE_PLACEHOLDER=false
# 可选模型: qwen-image-txt2img | z-image-turbo | seedream-4.0 | hunyuan-image-3
PPIO_IMAGE_MODEL=seedream-4.0
PPIO_IMAGE_POLL_TIMEOUT=120
# IMAGE_API_BASE_URL=https://api.openai.com/v1
# IMAGE_API_TIMEOUT=30
